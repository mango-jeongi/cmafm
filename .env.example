# CMAFM Global Configuration (Example)
# Copy this file to .env and configure the paths for your local setup.

# ── General Directories ──
CMAFM_DATA_DIR=../data
CMAFM_WEIGHTS_DIR=./weights
CMAFM_FIGURES_DIR=../figures
CMAFM_RUNS_DIR=./runs

# ── Dashboard & Inference ──
# Path to the Faster R-CNN (CMAFM) model weights
WEIGHTS_FASTER_RCNN="/path/to/CMAFM/runs/best.pth"

# Path to the CMAFM-YOLO model weights
WEIGHTS_CMAFM_YOLO="/path/to/CMAFM/weights/best.pt"

# Path to the ablation directory (containing rgb_only_best.pth and thermal_only_best.pth)
WEIGHTS_ABLATION_DIR="/path/to/CMAFM/runs/ablation"

# Path to the M3FD Dataset directory
DATASET_DIR="/path/to/datasets/M3FD"

# ── HPC / Slurm Configuration ──
SLURM_PARTITION=gpu
